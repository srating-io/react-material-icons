{
  "name": "@esmalley/react-material-icons",
  "version": "3.0.8",
  "private": false,
  "description": "",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./*": {
      "types": "./dist/types/*.d.ts",
      "import": "./dist/esm/*.js",
      "require": "./dist/cjs/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "prebuild": "bash build.sh",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly --outDir dist/types",
    "build:js": "node build.mjs",
    "build": "npm run clean && npm run build:types && npm run build:js && npm run fix:cjs",
    "fix:cjs": "node -e \"require('fs').writeFileSync('dist/cjs/package.json', JSON.stringify({type:'commonjs'}))\"",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/srating-io/react-material-icons.git"
  },
  "keywords": [],
  "author": "Evan Smalley",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/srating-io/react-material-icons/issues"
  },
  "homepage": "https://github.com/srating-io/react-material-icons#readme",
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@svgr/cli": "^8.1.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/glob": "^9.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.1.9",
    "esbuild": "^0.27.3",
    "glob": "^13.0.6",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@material-design-icons/svg": "^0.14.15"
  }
}
