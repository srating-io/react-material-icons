{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist/cjs",
    "rootDir": "./src",
  },
  "include": ["src"]
}